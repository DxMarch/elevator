@startuml modules
title Modules
' high-level module architecture

skinparam componentStyle rectangle
' skinparam linetype ortho
left to right direction

package "Controller" as Controller {
    component "FSM" as FSM
    component "Hardware" as Hardware

    Hardware --> FSM : sensor events
    FSM --> Hardware : output commands
}

package "Orders" as Orders {
    component "HallOrders" as HallOrders
    component "CabOrders" as CabOrders
    component "Communicator" as Communicator

    Communicator --> HallOrders : synced updates
    Communicator --> CabOrders : synced updates
    HallOrders ..> Communicator
    CabOrders ..> Communicator
}

Hardware --> Orders : button events
FSM --> Orders : floor arrival
FSM ..> Orders

legend right
solid line  : updates/signals
dotted line : reads
endlegend
@enduml
